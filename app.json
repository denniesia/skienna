{
  "expo": {
    "name": "skienna",
    "slug": "skienna",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/skienna_logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/skienna_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/skienna_logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/skienna_logo.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow Skienna to access your camera",
          "photosPermission": "The app accesses your photos to let you share them with your friends."
        }
      ],
      "@react-native-community/datetimepicker"
    ]
  }
}
